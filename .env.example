AI_BACKEND_BASE_URL=http://127.0.0.1:8000

# Backend LLM chatbot. Required for online chatbot responses.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_OUTPUT_TOKENS=600
GROQ_TEMPERATURE=0.4

# Legacy Gemini settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=600
GEMINI_TEMPERATURE=0.4

# Optional premium translation fallback for backend /translate.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional observability. Leave blank for zero-cost local development.
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Backend persistence. Use sqlite for startup-style local production,
# postgres for production, or json if you need the old file-only behavior.
INTERACTION_STORAGE_BACKEND=sqlite
APP_DB_FILE=data/app.sqlite3
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nepal_tourism

# Backend auth. Change the secret before deploying outside local development.
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=43200
AUTH_USERS_FILE=data/auth_users.json
