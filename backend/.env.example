# Copy this file to backend/.env, then fill in your local secrets.

# Environment
ENVIRONMENT=development
# Set to 'production' to enforce strict secret validation.
OFFLINE_MODE=false
# Set to true to skip all external API calls and use local fallbacks only.

# Security
AUTH_SECRET_KEY=change-this-auth-secret-in-production
# Generate a secure key:
# python -c "import secrets; print(secrets.token_hex(32))"
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=43200
AUTH_USERS_FILE=data/auth_users.json

# CORS
ALLOWED_ORIGINS=*
# For production: ALLOWED_ORIGINS=https://yourdomain.com

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nepal_tourism
INTERACTION_STORAGE_BACKEND=postgres
# Use 'sqlite' for local dev without Docker.
APP_DB_FILE=data/app.sqlite3

# Redis recommendation cache
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=300
REDIS_ENABLED=false
# Keep false for normal local development; set true to cache recommendations.

# AI / LLM keys
GROQ_API_KEY=
# Get free key at https://console.groq.com
GEMINI_API_KEY=
# Get free key at https://aistudio.google.com
ANTHROPIC_API_KEY=
# Optional. Used as premium translation fallback only.

# Model settings - safe to leave as defaults
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_OUTPUT_TOKENS=600
GROQ_TEMPERATURE=0.4

GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=600
GEMINI_TEMPERATURE=0.4

ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Recommendation model settings - safe to leave as defaults
MODEL_NAME=all-MiniLM-L6-v2
RETRIEVE_TOP_K=30
FINAL_TOP_K=10
RETRIEVAL_SEMANTIC_WEIGHT=0.72
RETRIEVAL_ACTIVITY_WEIGHT=0.18
RETRIEVAL_CATEGORY_WEIGHT=0.10
SEMANTIC_WEIGHT=0.60
COLLABORATIVE_WEIGHT=0.10
CONTEXTUAL_WEIGHT=0.30
ACTIVITY_WEIGHT=0.22
VIBE_WEIGHT=0.14
SEASON_WEIGHT=0.16
BUDGET_WEIGHT=0.16
ACCESSIBILITY_WEIGHT=0.10
FAMILY_WEIGHT=0.08
ACCOMMODATION_WEIGHT=0.14
MAX_RESULTS_PER_DISTRICT=2
MAX_RESULTS_PER_CATEGORY=2
MODEL_DIR=models
RANDOM_SEED=42
