# Copy this file to backend/.env for local backend development.

# Required for online chatbot responses.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_OUTPUT_TOKENS=600
GROQ_TEMPERATURE=0.4

# Optional legacy Gemini settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=600
GEMINI_TEMPERATURE=0.4

# Optional premium translation fallback for /translate.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Get your free API key from https://www.pexels.com/api/
PEXELS_API_KEY=

# Backend persistence.
INTERACTION_STORAGE_BACKEND=sqlite
APP_DB_FILE=data/app.sqlite3
DATABASE_URL=

# CORS origins. Use * for development, specific URLs for production.
ALLOWED_ORIGINS=*

# Set to 'production' to enforce strict secret validation.
ENVIRONMENT=development

# Required in production. scripts/setup_env.py generates this automatically.
AUTH_SECRET_KEY=
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=43200
AUTH_USERS_FILE=data/auth_users.json
